{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "prisma/**/*.ts",
    "scripts/**/*.ts",
    "scripts/**/*.mts",
    "types/**/*.ts",
    "types/**/*.tsx",
    "instrumentation.ts",
    "next.config.ts",
    "prisma.config.ts",
    "proxy.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "*.mts"
  ],
  "exclude": ["node_modules", "backups", "cafe-saas", "oh-my-codex-repo", "oh-my-codex", "oh-my-codex-src", "codex-plugin-cc", ".omx", ".tmp"]
}
